<script>
  // Dynamic CTA UX: Scroll & highlight newsletter email input
  const proCta = document.querySelector('.pricing-pro-cta');
  
  if (proCta) {
    proCta.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector('#newsletter');
      const input = document.querySelector('#newsletter-email') as HTMLInputElement;
      
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
        
        // Wait for smooth scroll to finish, then focus & animate input
        setTimeout(() => {
          if (input) {
            input.focus();
            input.classList.add('pulse-highlight');
            
            // Remove highlight class after animation completes
            setTimeout(() => {
              input.classList.remove('pulse-highlight');
            }, 1500);
          }
        }, 800);
      }
    });
  }
</script>

