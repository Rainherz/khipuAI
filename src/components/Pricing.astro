<section id="precios" class="section pricing">
  <div class="container">
    <h2 class="section-title">Planes y precios</h2>
    <p class="section-subtitle">Empieza gratis. Cuando estés listo, el plan PRO desbloquea todo sin límites.</p>

    <!-- Selector de Facturación -->
    <div class="billing-toggle-container">
      <button id="btn-monthly" class="billing-toggle-btn active" type="button">
        Mensual
      </button>
      <button id="btn-semestral" class="billing-toggle-btn" type="button">
        Semestral <span class="discount-badge">(4 meses) — Ahorra 37.5%</span>
      </button>
    </div>

    <div class="pricing-grid">
      <div class="plan">
        <h3 class="plan-name">FREE</h3>
        <div class="plan-price-container">
          <div class="plan-price">Gratis</div>
        </div>
        <p class="plan-desc">Perfecto para empezar y probar todo el potencial de Khipu AI.</p>
        <ul class="plan-features">
          <li><span class="check">✓</span> 30 subidas de archivos/mes</li>
          <li><span class="check">✓</span> 20 mensajes al tutor/día</li>
          <li><span class="check">✓</span> Hasta 3 cursos</li>
          <li><span class="check">✓</span> 2 exámenes generados</li>
          <li><span class="check">✓</span> Flashcards SM-2 ilimitadas</li>
          <li><span class="check">✓</span> Grafo de conocimiento ilimitado</li>
          <li><span class="check">✓</span> Guía de estudio ilimitada</li>
        </ul>
        <a href="#download" class="btn btn-secondary btn-large" data-track="click_plan_free">Comenzar gratis</a>
      </div>
      <div class="plan plan-pro">
        <div class="pro-badge">Recomendado</div>
        <h3 class="plan-name">PRO</h3>
        <div class="plan-price-container">
          <div id="price-monthly" class="plan-price active-price">
            4 USD<span class="price-period">/ mes</span>
          </div>
          <div id="price-semestral" class="plan-price hidden-price">
            10 USD<span class="price-period">/ 4 meses</span>
            <div class="price-equivalent">Equivale a 2.50 USD / mes</div>
          </div>
        </div>
        <p class="plan-desc">Para estudiantes que quieren sacar el máximo provecho sin restricciones.</p>
        <ul class="plan-features">
          <li><span class="check">✓</span> Subidas de archivos ilimitadas</li>
          <li><span class="check">✓</span> Mensajes al tutor ilimitados</li>
          <li><span class="check">✓</span> Cursos ilimitados</li>
          <li><span class="check">✓</span> Exámenes generados ilimitados</li>
          <li><span class="check">✓</span> Flashcards SM-2 ilimitadas</li>
          <li><span class="check">✓</span> Grafo de conocimiento ilimitado</li>
          <li><span class="check">✓</span> Guía de estudio ilimitada</li>
        </ul>
        <a href="#newsletter" class="btn btn-primary btn-large pricing-pro-cta" data-track="click_plan_pro">Saber más PRO</a>
      </div>
    </div>
  </div>
</section>

<script>
  // Dynamic CTA UX: Scroll & highlight newsletter email input
  const proCta = document.querySelector('.pricing-pro-cta');
  
  if (proCta) {
    proCta.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector('#newsletter');
      const input = document.querySelector('#newsletter-email') as HTMLInputElement;
      
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
        
        // Wait for smooth scroll to finish, then focus & animate input
        setTimeout(() => {
          if (input) {
            input.focus();
            input.classList.add('pulse-highlight');
            
            // Remove highlight class after animation completes
            setTimeout(() => {
              input.classList.remove('pulse-highlight');
            }, 1500);
          }
        }, 800);
      }
    });
  }

  // Pricing toggle logic
  const btnMonthly = document.getElementById('btn-monthly');
  const btnSemestral = document.getElementById('btn-semestral');
  const priceMonthly = document.getElementById('price-monthly');
  const priceSemestral = document.getElementById('price-semestral');

  if (btnMonthly && btnSemestral && priceMonthly && priceSemestral) {
    btnMonthly.addEventListener('click', () => {
      btnMonthly.classList.add('active');
      btnSemestral.classList.remove('active');
      
      priceMonthly.classList.remove('hidden-price');
      priceMonthly.classList.add('active-price');
      
      priceSemestral.classList.remove('active-price');
      priceSemestral.classList.add('hidden-price');
    });

    btnSemestral.addEventListener('click', () => {
      btnSemestral.classList.add('active');
      btnMonthly.classList.remove('active');
      
      priceSemestral.classList.remove('hidden-price');
      priceSemestral.classList.add('active-price');
      
      priceMonthly.classList.remove('active-price');
      priceMonthly.classList.add('hidden-price');
    });
  }
</script>

