<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/logo.jpeg" alt="Khipu AI" class="brand-logo" />
      <span class="brand-name">Khipu AI</span>
    </a>

    <button class="mobile-menu-toggle" aria-label="Abrir menú" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="nav">
      <a href="/#como-funciona" class="nav-link">Cómo funciona</a>
      <a href="/#funcionalidades" class="nav-link">Funcionalidades</a>
      <a href="/#capturas" class="nav-link">Capturas</a>
      <a href="/#precios" class="nav-link">Precios</a>
      <a href="/#faq" class="nav-link">FAQ</a>
      <a href="/download" class="btn btn-primary nav-btn" data-track="click_download">Descargar APK</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const nav = document.querySelector('.nav');
  const links = document.querySelectorAll('.nav-link, .nav-btn');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('active');
      toggle.classList.toggle('open');
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('active');
        toggle.classList.remove('open');
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 1.25rem;
    z-index: 110;
  }

  .brand-logo {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .nav a:not(.btn) {
    color: var(--color-text-muted);
    transition: color 0.15s ease;
  }

  .nav a:not(.btn):hover {
    color: var(--color-primary);
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 110;
    padding: 0;
  }

  .mobile-menu-toggle .bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
  }

  /* Hamburger animations */
  .mobile-menu-toggle.open .bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .mobile-menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle.open .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .mobile-menu-toggle {
      display: flex;
    }

    .nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 100%;
      height: 100vh;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(12px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      transition: right 0.3s ease;
      z-index: 105;
      padding: 2rem;
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.05);
    }

    .nav.active {
      right: 0;
    }

    .nav a:not(.btn) {
      font-size: 1.25rem;
    }
  }
</style>
