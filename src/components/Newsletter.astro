<section id="newsletter" class="section newsletter">
  <div class="container">
    <div class="newsletter-card">
      <div class="newsletter-content">
        <h2 class="newsletter-title">¿Quieres acceso PRO?</h2>
        <p class="newsletter-text">Déjanos tu correo y te avisaremos cuando el plan PRO esté disponible.</p>
        
        <form class="newsletter-form" id="newsletter-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <input 
            type="email" 
            name="email" 
            id="newsletter-email" 
            placeholder="tu@email.com" 
            required 
            class="newsletter-input" 
            autocomplete="email" 
          />
          <button type="submit" class="btn btn-primary newsletter-btn" id="newsletter-submit-btn">
            <span class="btn-text">Suscribirme</span>
            <span class="btn-loader" style="display: none;">
              <svg class="spinner" viewBox="0 0 50 50">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
              </svg>
              Enviando...
            </span>
          </button>
        </form>

        <div id="newsletter-success" class="newsletter-success-msg" style="display: none;">
          <div class="success-icon">🎉</div>
          <h3>¡Te has registrado con éxito!</h3>
          <p>Gracias por tu interés en Khipu AI PRO. Te avisaremos en cuanto esté disponible.</p>
        </div>

        <div id="newsletter-error" class="newsletter-error-msg" style="display: none;">
          <p>Ocurrió un error. Por favor, verifica tu correo e inténtalo de nuevo.</p>
        </div>

        <p class="newsletter-note">Usamos Formspree. Reemplaza <code>YOUR_FORM_ID</code> en el código con tu ID real de Formspree.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
  const submitBtn = document.getElementById('newsletter-submit-btn') as HTMLButtonElement;
  const btnText = submitBtn?.querySelector('.btn-text') as HTMLElement;
  const btnLoader = submitBtn?.querySelector('.btn-loader') as HTMLElement;
  const successDiv = document.getElementById('newsletter-success') as HTMLElement;
  const errorDiv = document.getElementById('newsletter-error') as HTMLElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const action = form.action;

      // Reset states
      if (errorDiv) errorDiv.style.display = 'none';
      
      // Loading state
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.style.display = 'none';
      if (btnLoader) btnLoader.style.display = 'inline-flex';

      // Simular éxito local para pruebas si no se ha configurado el ID real
      if (action.includes('YOUR_FORM_ID')) {
        console.warn('Formspree YOUR_FORM_ID no configurado. Simulando envío exitoso localmente.');
        setTimeout(() => {
          if (form) form.style.display = 'none';
          if (successDiv) successDiv.style.display = 'block';
        }, 1200);
        return;
      }

      try {
        const response = await fetch(action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          if (form) form.style.display = 'none';
          if (successDiv) successDiv.style.display = 'block';
        } else {
          throw new Error('Formspree submit failed');
        }
      } catch (err) {
        console.error('Error submitting form:', err);
        if (errorDiv) errorDiv.style.display = 'block';
        if (submitBtn) submitBtn.disabled = false;
        if (btnText) btnText.style.display = 'inline-block';
        if (btnLoader) btnLoader.style.display = 'none';
      }
    });
  }
</script>

