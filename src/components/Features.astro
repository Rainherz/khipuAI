<script>
  // Connect Feature Cards with Interactive Hero Simulator
  const demoLinks = document.querySelectorAll('[data-mockup-target]');

  demoLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetScreen = link.getAttribute('data-mockup-target');
      
      // Scroll to Hero
      const heroSection = document.querySelector('.hero');
      if (heroSection) {
        heroSection.scrollIntoView({ behavior: 'smooth' });
        
        // After scroll completes, switch the mockup screen
        setTimeout(() => {
          const navItem = document.querySelector(`.phone-navbar .nav-item[data-target="${targetScreen}"]`) as HTMLButtonElement;
          if (navItem) {
            navItem.click();
            
            // Make sure the flashcard is not flipped
            if (targetScreen === 'screen-flashcards') {
              const card = document.getElementById('interactive-card');
              if (card) card.classList.remove('flipped');
            }
          }
        }, 850);
      }
    });
  });
</script>

