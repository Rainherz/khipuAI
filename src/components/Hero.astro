                    <div class="progress-bar-fill" style="width: 60%"></div>
                  </div>
                  <span class="progress-label">6/10 repasados</span>
                </div>
              </div>

              <div class="planner-grid">
                <div class="planner-card">
                  <span class="planner-stat">🔥 5</span>
                  <span class="planner-subtitle">Racha</span>
                </div>
                <div class="planner-card">
