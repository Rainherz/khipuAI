<script>
  // Mockup Tab Switching
  const navItems = document.querySelectorAll('.phone-navbar .nav-item');
  const screens = document.querySelectorAll('.phone-screen-content');
  const triggerBtn = document.querySelector('.trigger-flashcards');
  const card = document.getElementById('interactive-card');
  const rateBtns = document.querySelectorAll('.rate-btn');

  function switchScreen(targetId: string) {
    screens.forEach(screen => {
      screen.classList.remove('active');
    });
    navItems.forEach(item => {
      item.classList.remove('active');
    });

    const targetScreen = document.getElementById(targetId);
    const targetNavItem = document.querySelector(`[data-target="${targetId}"]`);
    
    if (targetScreen) targetScreen.classList.add('active');
    if (targetNavItem) targetNavItem.classList.add('active');
  }

  navItems.forEach(item => {
    item.addEventListener('click', () => {
      const target = item.getAttribute('data-target');
      if (target) switchScreen(target);
    });
  });

  if (triggerBtn) {
    triggerBtn.addEventListener('click', () => {
      switchScreen('screen-flashcards');
    });
  }

  // Interactive Card Flip
  if (card) {
    card.addEventListener('click', (e) => {
      // Evitar voltear si se hace clic en botones de calificación
      if ((e.target as HTMLElement).closest('.rating-buttons')) {
        return;
      }
      card.classList.toggle('flipped');
    });
  }

  // Simulate Rating Click
  rateBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      rateBtns.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      
      // Auto flip back and show next simulated concept after 1 second
      setTimeout(() => {
        if (card) {
          card.classList.remove('flipped');
          // Cambiar texto de pregunta y respuesta para simular avance
          setTimeout(() => {
            const questionElement = card.querySelector('.card-q');
            const definitionElement = card.querySelector('.definition');
            
            if (questionElement && definitionElement) {
              if (questionElement.textContent === 'Repetición Espaciada') {
                questionElement.textContent = 'Algoritmo SM-2';
                definitionElement.textContent = 'Algoritmo que calcula el intervalo de repaso óptimo basado en la curva del olvido y tu autoevaluación.';
              } else {
                questionElement.textContent = 'Repetición Espaciada';
                definitionElement.textContent = 'Técnica de aprendizaje que programa repasos en intervalos de tiempo crecientes según tu nivel de recuerdo.';
              }
            }
            rateBtns.forEach(b => b.classList.remove('selected'));
          }, 400);
        }
      }, 1000);
    });
  });
</script>

