---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Khipu AI — Panel de Control Administrativo"
  description="Panel privado para visualizar métricas de descargas, accesos, suscripciones y precisión del producto."
>
  <Header />
  <main class="admin-main">
    <div class="container">
      <div class="admin-header">
        <div>
          <h1 class="admin-title">Panel de Métricas</h1>
          <p class="admin-subtitle">Monitoreo de descargas, adquisición y precisión de la IA de Khipu AI.</p>
        </div>
        <div class="connection-status-badge connecting" id="connection-status">
          <span class="status-dot"></span>
          <span class="status-text">Sincronizando...</span>
        </div>
      </div>

      <!-- Panel de Métricas Principal -->
      <div class="metrics-grid">
        <!-- Tarjeta 1: Usuarios Totales -->
        <div class="metric-card glass-card">
          <div class="metric-header">
            <span class="metric-label">Usuarios Totales</span>
            <div class="metric-icon users-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
          </div>
          <div class="metric-value" id="val-total-users">--</div>
          <div class="metric-change positive">
            <span>↑ 12% este mes</span>
          </div>
        </div>

        <!-- Tarjeta 2: Suscripciones PRO -->
        <div class="metric-card glass-card pro-card">
          <div class="metric-header">
            <span class="metric-label text-white">Suscripciones PRO</span>
            <div class="metric-icon pro-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
          </div>
          <div class="metric-value text-white" id="val-pro-users">--</div>
          <div class="metric-change text-white-muted">
            <span id="val-conversion-rate">Tasa de conversión: --</span>
          </div>
        </div>

        <!-- Tarjeta 3: Descargas del APK -->
        <div class="metric-card glass-card">
          <div class="metric-header">
            <span class="metric-label">Descargas APK (Plausible)</span>
            <div class="metric-icon downloads-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
          </div>
          <div class="metric-value" id="val-apk-downloads">--</div>
          <div class="metric-change positive">
            <span>En base a clics de descarga</span>
          </div>
        </div>

        <!-- Tarjeta 4: Precisión del Producto -->
        <div class="metric-card glass-card">
          <div class="metric-header">
            <span class="metric-label">Precisión de IA (Historial SM-2)</span>
            <div class="metric-icon precision-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 4.24 4.24"/><path d="m14.83 9.17 4.24-4.24"/><path d="m14.83 14.83 4.24 4.24"/><path d="m9.17 14.83-4.24 4.24"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
          </div>
          <div class="precision-score-wrapper">
            <div class="metric-value" id="val-precision">--<span class="max-score">/ 5.0</span></div>
            <div class="precision-badge" id="val-precision-label">Excelente</div>
          </div>
          <div class="metric-change positive">
            <span>Basado en calificaciones SM-2</span>
          </div>
        </div>
      </div>

      <div class="details-grid">
        <!-- Gráfico / Estadísticas de Uso Diario -->
        <div class="details-card glass-card usage-stats">
          <h2 class="card-title">Interacción y Uso del Sistema (Mensual)</h2>
          <p class="card-desc">Cantidad total de recursos solicitados por los estudiantes en la plataforma móvil.</p>
          
          <div class="usage-bar-chart">
            <div class="chart-bar-item">
              <div class="bar-label-group">
                <span>Subidas de Documentos (PDF/Fotos)</span>
                <strong id="val-usage-captures">--</strong>
              </div>
              <div class="bar-track">
                <div class="bar-fill captures-fill" style="width: 75%"></div>
              </div>
            </div>
            
            <div class="chart-bar-item">
              <div class="bar-label-group">
                <span>Mensajes Enviados al Tutor IA</span>
                <strong id="val-usage-messages">--</strong>
              </div>
              <div class="bar-track">
                <div class="bar-fill messages-fill" style="width: 90%"></div>
              </div>
            </div>

            <div class="chart-bar-item">
              <div class="bar-label-group">
                <span>Exámenes Generados</span>
                <strong id="val-usage-exams">--</strong>
              </div>
              <div class="bar-track">
                <div class="bar-fill exams-fill" style="width: 45%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Feedback del Historial de Flashcards (SM-2) -->
        <div class="details-card glass-card reviews-card">
          <h2 class="card-title">Historial Reciente de Repasos (SM-2)</h2>
          <p class="card-desc">Últimos conceptos evaluados y calificados por los usuarios del 0 al 5.</p>
          
          <div class="reviews-list" id="reviews-container">
            <!-- Cargado por JS -->
          </div>
        </div>
      </div>


    </div>
  </main>
  <Footer />
</Layout>

<script>
  interface DashboardData {
    totalUsers: number;
    proUsers: number;
    totalDownloads: number;
    averageRating: number;
    usage: {
      captures: number;
      tutorMessages: number;
      examsGenerated: number;
    };
    recentReviews: {
      id: number;
      date: string;
      rating: number;
      concept: string;
    }[];
  }

  // Selectores DOM
  const connectionStatus = document.getElementById('connection-status') as HTMLElement;

  // Selectores de valores métricos
  const elTotalUsers = document.getElementById('val-total-users');
  const elProUsers = document.getElementById('val-pro-users');
  const elConversionRate = document.getElementById('val-conversion-rate');
  const elApkDownloads = document.getElementById('val-apk-downloads');
  const elPrecision = document.getElementById('val-precision');
  const elPrecisionLabel = document.getElementById('val-precision-label');
  const elUsageCaptures = document.getElementById('val-usage-captures');
  const elUsageMessages = document.getElementById('val-usage-messages');
  const elUsageExams = document.getElementById('val-usage-exams');
  const reviewsContainer = document.getElementById('reviews-container');

  // Cargar credenciales e intentar conexión automática
  window.addEventListener('DOMContentLoaded', () => {
    const defaultUrl = import.meta.env.PUBLIC_API_URL || 'https://khipu-ai-backend-1013222499074.us-central1.run.app/v1/admin/metrics';
    const defaultToken = import.meta.env.PUBLIC_API_TOKEN || 'cambia-esto-por-un-string-aleatorio-de-64-chars';

    connectToAPI(defaultUrl, defaultToken);
  });

  // Función para conectarse a la API real
  async function connectToAPI(url: string, token: string) {
    if (connectionStatus) {
      connectionStatus.className = 'connection-status-badge connecting';
      connectionStatus.querySelector('.status-text')!.textContent = 'Sincronizando...';
    }

    try {
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/json'
        }
      });

      if (!response.ok) throw new Error('Falló la conexión con el servidor API');

      const data = await response.json();
      renderData(data);

      if (connectionStatus) {
        connectionStatus.className = 'connection-status-badge connected';
        connectionStatus.querySelector('.status-text')!.textContent = 'En Vivo';
      }
    } catch (err) {
      console.error(err);
      if (connectionStatus) {
        connectionStatus.className = 'connection-status-badge error';
        connectionStatus.querySelector('.status-text')!.textContent = 'Sin conexión';
      }
      renderEmptyState();
    }
  }

  // Renderizar los datos en el dashboard
  function renderData(data: DashboardData) {
    if (elTotalUsers) elTotalUsers.textContent = data.totalUsers.toLocaleString();
    if (elProUsers) elProUsers.textContent = data.proUsers.toLocaleString();
    
    // Tasa de conversión
    if (elConversionRate) {
      const rate = ((data.proUsers / data.totalUsers) * 100).toFixed(1);
      elConversionRate.textContent = `Tasa de conversión: ${rate}%`;
    }

    if (elApkDownloads) elApkDownloads.textContent = data.totalDownloads.toLocaleString();
    
    // Precisión SM-2
    if (elPrecision) {
      elPrecision.innerHTML = `${data.averageRating.toFixed(2)}<span class="max-score">/ 5.0</span>`;
    }

    if (elPrecisionLabel) {
      if (data.averageRating >= 4.5) {
        elPrecisionLabel.textContent = 'Sobresaliente';
        elPrecisionLabel.className = 'precision-badge outstanding';
      } else if (data.averageRating >= 4.0) {
        elPrecisionLabel.textContent = 'Excelente';
        elPrecisionLabel.className = 'precision-badge excellent';
      } else {
        elPrecisionLabel.textContent = 'Buena';
        elPrecisionLabel.className = 'precision-badge good';
      }
    }

    // Uso
    if (elUsageCaptures) elUsageCaptures.textContent = data.usage.captures.toLocaleString();
    if (elUsageMessages) elUsageMessages.textContent = data.usage.tutorMessages.toLocaleString();
    if (elUsageExams) elUsageExams.textContent = data.usage.examsGenerated.toLocaleString();

    // Actualizar barras de gráfico
    const maxUsage = Math.max(data.usage.captures, data.usage.tutorMessages, data.usage.examsGenerated);
    document.querySelector('.captures-fill')!.setAttribute('style', `width: ${(data.usage.captures / maxUsage) * 100}%`);
    document.querySelector('.messages-fill')!.setAttribute('style', `width: ${(data.usage.tutorMessages / maxUsage) * 100}%`);
    document.querySelector('.exams-fill')!.setAttribute('style', `width: ${(data.usage.examsGenerated / maxUsage) * 100}%`);

    // Listado de reseñas/repasos
    if (reviewsContainer) {
      reviewsContainer.innerHTML = '';
      data.recentReviews.forEach((review) => {
        const item = document.createElement('div');
        item.className = 'review-item';
        
        let stars = '';
        for (let i = 1; i <= 5; i++) {
          stars += `<span class="star ${i <= review.rating ? 'active' : ''}">★</span>`;
        }

        item.innerHTML = `
          <div class="review-meta">
            <span class="review-concept">${review.concept}</span>
            <span class="review-date">${review.date}</span>
          </div>
          <div class="review-stars">
            ${stars}
            <span class="review-rating-num">${review.rating}/5</span>
          </div>
        `;
        reviewsContainer.appendChild(item);
      });
    }
  }

  // Renderizar estado vacío cuando no hay conexión con la API
  function renderEmptyState() {
    if (elTotalUsers) elTotalUsers.textContent = '--';
    if (elProUsers) elProUsers.textContent = '--';
    if (elConversionRate) elConversionRate.textContent = 'Tasa de conversión: --';
    if (elApkDownloads) elApkDownloads.textContent = '--';
    if (elPrecision) elPrecision.innerHTML = '--<span class="max-score">/ 5.0</span>';
    if (elPrecisionLabel) {
      elPrecisionLabel.textContent = 'Sin datos';
      elPrecisionLabel.className = 'precision-badge';
    }
    if (elUsageCaptures) elUsageCaptures.textContent = '--';
    if (elUsageMessages) elUsageMessages.textContent = '--';
    if (elUsageExams) elUsageExams.textContent = '--';

    document.querySelector('.captures-fill')!.setAttribute('style', 'width: 0%');
    document.querySelector('.messages-fill')!.setAttribute('style', 'width: 0%');
    document.querySelector('.exams-fill')!.setAttribute('style', 'width: 0%');

    if (reviewsContainer) {
      reviewsContainer.innerHTML = '<div class="review-item"><span class="review-concept">No hay repasos recientes</span></div>';
    }
  }
</script>

<style>
  .admin-main {
    background: #f8fafc;
    padding: 3rem 0;
    min-height: 80vh;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .admin-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .admin-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  /* Badges de Conexión */
  .connection-status-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.85rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
  }

  .connection-status-badge.disconnected {
    background: #f1f5f9;
    color: #64748b;
    border: 1px solid #cbd5e1;
  }

  .connection-status-badge.disconnected .status-dot {
    background: #94a3b8;
  }

  .connection-status-badge.connecting {
    background: #fef3c7;
    color: #b45309;
    border: 1px solid #fde68a;
  }

  .connection-status-badge.connecting .status-dot {
    background: #f59e0b;
    animation: pulse 1.5s infinite;
  }

  .connection-status-badge.connected {
    background: #dcfce7;
    color: #15803d;
    border: 1px solid #bbf7d0;
  }

  .connection-status-badge.connected .status-dot {
    background: #22c55e;
  }

  .connection-status-badge.error {
    background: #fee2e2;
    color: #b91c1c;
    border: 1px solid #fecaca;
  }

  .connection-status-badge.error .status-dot {
    background: #ef4444;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  /* Tarjetas Generales (Glassmorphic) */
  .glass-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  /* Formulario de Configuración */
  .config-card {
    margin-bottom: 2.5rem;
  }

  .card-title {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .config-form {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .form-group {
    flex: 1;
    min-width: 250px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-input {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid #cbd5e1;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-input:focus {
    border-color: var(--color-primary);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
  }

  /* Grilla de Tarjetas Métricas */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 160px;
  }

  .pro-card {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    border-color: var(--color-primary-light);
  }

  .pro-card .metric-label {
    color: rgba(255, 255, 255, 0.9);
  }

  .pro-card .metric-value {
    color: white;
  }

  .pro-card .metric-change {
    color: rgba(255, 255, 255, 0.85);
  }

  .metric-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .metric-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .metric-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    background: #f1f5f9;
    color: var(--color-primary);
  }

  .pro-card .metric-icon {
    background: rgba(255, 255, 255, 0.15);
    color: white;
  }

  .metric-value {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .metric-change {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .metric-change.positive {
    color: var(--color-success);
  }

  .text-white-muted {
    color: rgba(255, 255, 255, 0.8);
  }

  /* Puntuación de Precisión */
  .precision-score-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .max-score {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .precision-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .precision-badge.outstanding {
    background: #dcfce7;
    color: #15803d;
  }

  .precision-badge.excellent {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .precision-badge.good {
    background: #fef3c7;
    color: #d97706;
  }

  /* Estructura de Detalles (Gráficos / Listas) */
  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  @media (max-width: 900px) {
    .details-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Barras de Uso */
  .usage-bar-chart {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .bar-label-group {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }

  .bar-label-group span {
    font-weight: 500;
    color: var(--color-text);
  }

  .bar-label-group strong {
    font-weight: 700;
  }

  .bar-track {
    width: 100%;
    height: 10px;
    background: #f1f5f9;
    border-radius: 999px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .captures-fill {
    background: var(--color-primary);
  }

  .messages-fill {
    background: var(--color-secondary);
  }

  .exams-fill {
    background: var(--color-success);
  }

  /* Listado de Reviews */
  .reviews-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
    max-height: 250px;
    overflow-y: auto;
    padding-right: 0.5rem;
  }

  .review-item {
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: #f8fafc;
    border: 1px solid rgba(0, 0, 0, 0.02);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
  }

  .review-concept {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .review-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .review-stars {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .star {
    color: #cbd5e1;
    font-size: 1.1rem;
  }

  .star.active {
    color: #fbbf24;
  }

  .review-rating-num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }

  /* Guía de Desarrollador */
  .json-code {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.5rem;
    border-radius: 1rem;
    overflow-x: auto;
    font-size: 0.85rem;
    border: 1px solid #1e293b;
    margin-top: 1rem;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.7;
    }
  }
</style>

